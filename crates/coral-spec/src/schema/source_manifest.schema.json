          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "when_arg": { "type": "string", "minLength": 1 },
        "from": { "type": "string" },
        "template": { "type": "string" },
        "value": {},
        "key": { "type": "string", "minLength": 1 },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "values": {
          "type": "array",
          "minItems": 1,
