    "response": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": ["json", "json_each_row"]
        },
        "rows_path": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
