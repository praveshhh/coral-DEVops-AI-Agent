        "part": { "type": "integer", "minimum": 0 }
      },
      "allOf": [{ "$ref": "#/$defs/value_source_switch" }]
    },
    "value_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from"],
      "properties": {
        "from": { "type": "string" },
        "template": { "type": "string" },
        "value": {},
        "key": { "type": "string", "minLength": 1 },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "values": {
          "type": "array",
