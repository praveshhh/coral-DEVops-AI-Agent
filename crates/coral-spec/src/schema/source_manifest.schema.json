        },
        "default": {},
        "seconds": { "type": "integer" },
        "separator": { "type": "string", "minLength": 1 },
        "part": { "type": "integer", "minimum": 0 }
      },
      "allOf": [{ "$ref": "#/$defs/value_source_switch" }]
    },
    "value_source_switch": {
      "oneOf": [
        {
          "properties": {
            "from": { "const": "template" },
